              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('demo token request succeeds', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('demo token is present', () => pm.expect(body.access_token).to.be.a('string').and.not.empty);",
                  "pm.environment.set('demo_token', body.access_token);"
