    {
      "name": "Public API",
      "item": [
        {
          "name": "List public bookmarks with v1 offset pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('public v1 feed is anonymous', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('v1 feed is a page', () => {",
                  "  pm.expect(body.items).to.be.an('array');",
                  "  pm.expect(body.page).to.be.a('number');",
                  "  pm.expect(body.size).to.be.a('number');",
                  "});",
                  "pm.test('deprecated v1 listing exposes successor headers', () => {",
                  "  pm.expect(pm.response.headers.get('Deprecation')).to.be.a('string').and.not.empty;",
                  "  pm.expect(pm.response.headers.get('Sunset')).to.be.a('string').and.not.empty;",
                  "  pm.expect(pm.response.headers.get('Link')).to.include('/api/v2/bookmarks');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{BACKEND_URL}}/api/v1/bookmarks?visibility=public&size=5"
          }
        },
        {
          "name": "List public bookmarks with v2 cursor pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('public v2 feed is anonymous', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('v2 feed is a cursor page', () => pm.expect(body.items).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{BACKEND_URL}}/api/v2/bookmarks?visibility=public&size=5"
          }
        },
        {
          "name": "Read localized message bundle",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('message bundle is public', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('bundle has English messages', () => {",
                  "  pm.expect(body.language).to.equal('en');",
                  "  pm.expect(body.messages).to.be.an('object');",
                  "});",
                  "pm.test('bundle is cacheable by ETag', () => {",
                  "  pm.expect(pm.response.headers.get('ETag')).to.be.a('string').and.not.empty;",
                  "  pm.expect(pm.response.headers.get('Cache-Control')).to.include('no-cache');",
                  "  pm.expect(pm.response.headers.get('Content-Language')).to.equal('en');",
                  "});",
                  "pm.environment.set('message_bundle_etag', pm.response.headers.get('ETag'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{BACKEND_URL}}/api/v1/messages/bundle?lang=en"
          }
        },
        {
          "name": "Revalidate localized message bundle",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('unchanged bundle returns 304', () => pm.response.to.have.status(304));",
                  "pm.test('304 response has no body', () => pm.expect(pm.response.text()).to.equal(''));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "If-None-Match",
                "value": "{{message_bundle_etag}}"
              }
            ],
            "url": "{{BACKEND_URL}}/api/v1/messages/bundle?lang=en"
          }
        }
      ]
    },
