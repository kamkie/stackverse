{
  "info": {
    "_postman_id": "e3290e89-0707-4d82-a155-39ad847d291a",
    "name": "Stackverse API Showcase",
    "description": "Representative Stackverse backend API workflows for Postman, Newman, and the Postman CLI. This is a showcase suite, not the canonical conformance gate.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const backendUrl = (pm.environment.get('BACKEND_URL') || 'http://localhost:8080').replace(/\\/+$/, '');",
          "const keycloakUrl = (pm.environment.get('KEYCLOAK_URL') || 'http://localhost:8180').replace(/\\/+$/, '');",
          "pm.environment.set('BACKEND_URL', backendUrl);",
          "pm.environment.set('KEYCLOAK_URL', keycloakUrl);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Initialize run and check liveness",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = `pm-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`;",
                  "pm.environment.set('run_id', runId);",
                  "pm.environment.set('showcase_tag', runId.slice(0, 30));",
                  "for (const key of ['demo_token', 'mentor_token', 'moderator_token', 'admin_token', 'message_bundle_etag', 'private_bookmark_id', 'public_bookmark_id', 'report_id', 'message_id']) {",
                  "  pm.environment.unset(key);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('backend is live', () => pm.response.to.have.status(200));",
                  "pm.test('run variables were initialized', () => {",
                  "  pm.expect(pm.environment.get('run_id')).to.match(/^pm-[a-z0-9]+-[a-z0-9]+$/);",
                  "  pm.expect(pm.environment.get('showcase_tag')).to.match(/^pm-[a-z0-9-]+$/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{BACKEND_URL}}/healthz"
          }
        },
        {
          "name": "Check readiness",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('backend dependencies are ready', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": "{{BACKEND_URL}}/readyz"
          }
        },
