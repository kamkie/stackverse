        {
          "name": "List demo tag counts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('tag counts succeed', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const tag = body.tags.find((item) => item.tag === pm.environment.get('showcase_tag'));",
                  "pm.test('created tag has usage count', () => {",
                  "  pm.expect(tag).to.exist;",
                  "  pm.expect(tag.count).to.be.at.least(2);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
