        {
          "name": "Create private demo bookmark",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('private bookmark is created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('private bookmark defaults are server managed', () => {",
                  "  pm.expect(body.id).to.match(/^[0-9a-f-]{36}$/);",
                  "  pm.expect(body.owner).to.equal('demo');",
                  "  pm.expect(body.visibility).to.equal('private');",
                  "  pm.expect(body.status).to.equal('active');",
                  "});",
                  "pm.environment.set('private_bookmark_id', body.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{demo_token}}",
                  "type": "string"
