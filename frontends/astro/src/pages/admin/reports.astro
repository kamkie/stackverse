---
import AdminNavigation from "../../components/admin/AdminNavigation";
import Reports from "../../components/admin/Reports";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Moderation reports - Stackverse">
  <div class="sv-layout">
    <AdminNavigation client:load currentPath={Astro.url.pathname} />
    <section class="sv-content">
      <header>
        <h1 class="sv-page-title">Moderation reports</h1>
        <p>Review, dismiss, action, and reopen submitted reports.</p>
      </header>
      <Reports client:load />
    </section>
  </div>
</BaseLayout>
