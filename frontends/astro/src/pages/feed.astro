---
import PublicBookmarkFeed from "../components/bookmarks/PublicBookmarkFeed";
import LocalizedText from "../components/LocalizedText";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Public feed - Stackverse">
  <section class="sv-content">
    <header>
      <h1 class="sv-page-title">
        <LocalizedText client:load message="ui.nav.public-feed" fallback="Public feed" />
      </h1>
      <p>Browse public bookmarks shared by the Stackverse community.</p>
    </header>
    <PublicBookmarkFeed client:load />
  </section>
</BaseLayout>
