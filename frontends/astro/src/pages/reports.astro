---
import UserReportList from "../components/reports/UserReportList";
import LocalizedText from "../components/LocalizedText";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="My reports - Stackverse">
  <section class="sv-content">
    <header>
      <h1 class="sv-page-title">
        <LocalizedText client:load message="ui.nav.my-reports" fallback="My reports" />
      </h1>
      <p>Track and update reports you submitted for public bookmarks.</p>
    </header>
    <UserReportList client:load />
  </section>
</BaseLayout>
