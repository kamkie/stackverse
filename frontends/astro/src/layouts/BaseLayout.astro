---
import Header from "../components/Header";
import "../../../../spec/design/tokens.css";
import "../../../../spec/design/stackverse.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Stackverse",
  description = "A contract-first bookmark manager implemented across many stacks.",
} = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline src="/theme.js"></script>
  </head>
  <body>
    <div class="sv-app">
      <Header client:load currentPath={currentPath} />
      <main class="sv-main"><slot /></main>
    </div>
  </body>
</html>
