{
  "name": "@stackverse/frontend-lit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "yarn lint && yarn format:check && yarn build && yarn test:coverage"
  },
  "dependencies": {
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@open-wc/testing-helpers": "^3.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.0.3",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
