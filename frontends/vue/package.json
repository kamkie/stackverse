{
  "name": "@stackverse/frontend-vue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@4.17.0+sha512.c2957de2f9025ab14d63b24d0d8be1f1655810e22c341042c27f7ecd017b180ec12db73d69ac366d71b304ef9f069349ce462de96f04f8f1da317f4f762c95ae",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "generate:api": "openapi-typescript ../../spec/openapi.yaml -o src/api/schema.ts --default-non-nullable false",
    "generate:api:check": "yarn generate:api --check"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "openapi-msw": "^2.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "dependenciesMeta": {
    "msw": {
      "built": false
    }
  }
}
