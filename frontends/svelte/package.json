{
  "name": "@stackverse/frontend-svelte",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697",
  "scripts": {
    "dev": "vite",
    "build": "yarn typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "yarn lint && yarn format:check && yarn build && yarn test:coverage"
  },
  "dependencies": {
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/svelte": "^5.2.9",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.13.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.0",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-check": "^4.7.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
