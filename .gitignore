# local env
.env

# dev-mode logs tee'd by scripts/dev-stack.ps1 (shared with agents, never committed)
.logs/

# Claude Code: launch.json (dev-server config) is committed; the rest is local
.claude/*
!.claude/launch.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp

# IDE (per-implementation ignores live in each implementation directory)
.idea/
.vscode/
*.iml

# common build outputs — implementations add their own specifics
node_modules/
target/
build/
bin/
obj/
dist/
out/

# Python runtime and tool artifacts — also covers repo-root helper scripts
__pycache__/
*.py[cod]
*.egg-info/
.venv*/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.nox/
.coverage
coverage.xml
htmlcov/

# test coverage output (JaCoCo lands under build/, these two don't)
coverage/
TestResults/
